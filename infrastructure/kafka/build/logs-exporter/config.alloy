// https://grafana.com/docs/alloy/latest/tutorials/send-logs-to-loki/
// https://grafana.com/docs/alloy/latest/tutorials/logs-and-relabeling-basics/

// ---------------------------------------------------------------------------------------------------------------------
// Server-A
// ---------------------------------------------------------------------------------------------------------------------

local.file_match "server_a_step_0_files" {
  path_targets = [{"__path__" = "/input/server-a/root.log"}, {"__path__" = "/input/server-a/logger.log"}]
  sync_period = "5s"
}
loki.source.file "server_a_step_1_scrap" {
  targets    = local.file_match.server_a_step_0_files.targets
  forward_to = [loki.relabel.server_a_step_2_labels.receiver]
}
loki.relabel "server_a_step_2_labels" {
  rule {
    target_label = "job"
    replacement = "infrastructure-kafka-server-a"
  }
  forward_to = [loki.write.step_3_push.receiver]
}

// ---------------------------------------------------------------------------------------------------------------------
// Server-B
// ---------------------------------------------------------------------------------------------------------------------

local.file_match "server_b_step_0_files" {
  path_targets = [{"__path__" = "/input/server-b/root.log"}, {"__path__" = "/input/server-b/logger.log"}]
  sync_period = "5s"
}
loki.source.file "server_b_step_1_scrap" {
  targets    = local.file_match.server_b_step_0_files.targets
  forward_to = [loki.relabel.server_b_step_2_labels.receiver]
}
loki.relabel "server_b_step_2_labels" {
  rule {
    target_label = "job"
    replacement = "infrastructure-kafka-server-b"
  }
  forward_to = [loki.write.step_3_push.receiver]
}

// ---------------------------------------------------------------------------------------------------------------------
// Server-C
// ---------------------------------------------------------------------------------------------------------------------

local.file_match "server_c_step_0_files" {
  path_targets = [{"__path__" = "/input/server-c/root.log"}, {"__path__" = "/input/server-c/logger.log"}]
  sync_period = "5s"
}
loki.source.file "server_c_step_1_scrap" {
  targets    = local.file_match.server_c_step_0_files.targets
  forward_to = [loki.relabel.server_c_step_2_labels.receiver]
}
loki.relabel "server_c_step_2_labels" {
  rule {
    target_label = "job"
    replacement = "infrastructure-kafka-server-c"
  }
  forward_to = [loki.write.step_3_push.receiver]
}

// ---------------------------------------------------------------------------------------------------------------------
// LOKI
// ---------------------------------------------------------------------------------------------------------------------

loki.write "step_3_push" {
  endpoint {
    url = "__LOKI_BASEURL__/loki/api/v1/push"
  }
}

// ---------------------------------------------------------------------------------------------------------------------
