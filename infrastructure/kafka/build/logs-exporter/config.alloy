// https://grafana.com/docs/alloy/latest/tutorials/send-logs-to-loki/
// https://grafana.com/docs/alloy/latest/tutorials/logs-and-relabeling-basics/

// ---------------------------------------------------------------------------------------------------------------------
// Broker-A
// ---------------------------------------------------------------------------------------------------------------------

local.file_match "broker_a_step_0_files" {
  path_targets = [{"__path__" = "/input/broker-a/root.log"}, {"__path__" = "/input/broker-a/logger.log"}]
  sync_period = "5s"
}
loki.source.file "broker_a_step_1_scrap" {
  targets    = local.file_match.broker_a_step_0_files.targets
  forward_to = [loki.relabel.broker_a_step_2_labels.receiver]
}
loki.relabel "broker_a_step_2_labels" {
  rule {
    target_label = "job"
    replacement = "infrastructure-kafka-broker-a"
  }
  forward_to = [loki.write.step_3_push.receiver]
}

// ---------------------------------------------------------------------------------------------------------------------
// Broker-B
// ---------------------------------------------------------------------------------------------------------------------

local.file_match "broker_b_step_0_files" {
  path_targets = [{"__path__" = "/input/broker-b/root.log"}, {"__path__" = "/input/broker-b/logger.log"}]
  sync_period = "5s"
}
loki.source.file "broker_b_step_1_scrap" {
  targets    = local.file_match.broker_b_step_0_files.targets
  forward_to = [loki.relabel.broker_b_step_2_labels.receiver]
}
loki.relabel "broker_b_step_2_labels" {
