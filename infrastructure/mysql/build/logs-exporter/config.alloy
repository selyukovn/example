// https://grafana.com/docs/alloy/latest/tutorials/send-logs-to-loki/
// https://grafana.com/docs/alloy/latest/tutorials/logs-and-relabeling-basics/

// ---------------------------------------------------------------------------------------------------------------------
// MASTER - ERROR
// ---------------------------------------------------------------------------------------------------------------------

local.file_match "step_0_files_master_error" {
  path_targets = [{"__path__" = "/input/master/log.error"}]
  sync_period = "5s"
}
loki.source.file "step_1_scrap_master_error" {
  targets    = local.file_match.step_0_files_master_error.targets
  forward_to = [loki.relabel.step_2_labels_master_error.receiver]
}
loki.relabel "step_2_labels_master_error" {
  rule {
    target_label = "job"
    replacement = "infrastructure-mysql-master"
  }
  forward_to = [loki.write.step_3_push.receiver]
}

// ---------------------------------------------------------------------------------------------------------------------
// MASTER - GENERAL
// ---------------------------------------------------------------------------------------------------------------------

local.file_match "step_0_files_master_general" {
  path_targets = [{"__path__" = "/input/master/log.general"}]
