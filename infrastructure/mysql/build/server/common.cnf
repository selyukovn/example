# ----------------------------------------------------------------------------------------------------------------------
# ПАПКИ
# ----------------------------------------------------------------------------------------------------------------------

# По умолчанию почти все файлы свалены кучей в основной каталог данных.
# Ради порядка и потенциальной возможности использования нескольких дисков разных характеристик
# хотел сгруппировать файлы в подпапки по аналогии со стандартными "#innodb_redo".
# Для бинлога, системного пространства, логов и т.д. использование подпапок силами одного файла конфига невозможно,
# т.к. мускуль сам не создает эти подпапки, docker-entrypoint из образа тоже,
# при инициализации сервера они уже должны существовать, но каталог данных при этом должен быть пуст.
# Т.е. можно использовать либо внешние папки, либо толстые костыли,
# что в обоих случаях усложнит настройку контейнера, но не принесет большой пользы.
# Так что сделал, где делалось, а в остальном осталось как было.

[mysqld]

innodb_doublewrite_dir="#innodb_dblwr"
innodb_undo_directory="#innodb_undo"

# Подпапку не создать, но хотя бы по имени файла рядом лежат.
log_bin="#binlog"
relay_log="#relay"
log_error="/var/lib/mysql/log.error"
general_log_file="/var/lib/mysql/log.general"
slow_query_log_file="/var/lib/mysql/log.slow"


# ----------------------------------------------------------------------------------------------------------------------
# ЛОГИ
# ----------------------------------------------------------------------------------------------------------------------

[mysqld]

# Файл, чтобы можно было экспортировать в графану.
log_output=FILE

slow_query_log=1
long_query_time=0.2
min_examined_row_limit=1

# Запросы без индексов (пишется в slow-лог независимо от длительности, если не был использован индекс) игнорируются:
# - во-первых, не всякий запрос без индекса плох.
# - во-вторых, prometheus-экспортер запрашивает "SELECT ... FROM information_schema.innodb_cmpmem;" каждые N секунд,
#   тем самым забивая весь slow-лог бесполезной информацией (и log_throttle_... параметр не добавит смысла).
#   Можно бы было попытаться отключить через performance_schema.setup_actors, но это какой-то костыль.
# Аналогичная ситуация c general-log -- слишком много бессмысленных запросов (prometheus, healthcheck, replica, ...).
# Админские запросы не имеет смысла логировать, даже если они медленные.
# Включать все это имеет смысл только на короткое время для диагностики в специфических случаях.
general_log=0
log_slow_admin_statements=0
log_queries_not_using_indexes=0
log_throttle_queries_not_using_indexes=1


# ----------------------------------------------------------------------------------------------------------------------
# СТРОГИЙ РЕЖИМ
# ----------------------------------------------------------------------------------------------------------------------

[mysqld]

sql_mode=STRICT_ALL_TABLES

# "...помогает избежать проблем с производительностью при репликации на основе строк ..."
sql_require_primary_key=ON

# ----------------------------------------------------------------------------------------------------------------------
